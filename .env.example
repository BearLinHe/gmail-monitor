# PostgreSQL connection string used by Prisma (see README)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gmail_monitor?schema=public"

# JSON array of Gmail accounts (use real 16-character App Passwords, not placeholders).
# In .env.local, keep this on one line or use JSON escaping for newlines.
GMAIL_ACCOUNTS_JSON='[{"email":"wgustruckingllc@gmail.com","region":"SAV","appPassword":"YOUR_APP_PASSWORD"},{"email":"kindaglobalinc@gmail.com","region":"OAK","appPassword":"YOUR_APP_PASSWORD"},{"email":"alreadyarrivedlogistics@gmail.com","region":"OAK","appPassword":"YOUR_APP_PASSWORD"},{"email":"info.ygtruckingllc@gmail.com","region":"OAK","appPassword":"YOUR_APP_PASSWORD"}]'

# Only scan mail received in the last N hours (default 72). Gmail search uses newer_than:ceil(N/24)d, then INTERNALDATE is checked.
# SCAN_LOOKBACK_HOURS=72

# Secret for scheduled scans.
# - If deploying on Vercel, set CRON_SECRET in project envs (Vercel sends Authorization: Bearer <CRON_SECRET>).
# - You may also set SCAN_CRON_SECRET for non-Vercel schedulers that call /api/scan-gmail/cron.
# CRON_SECRET="replace-with-long-random-string"
# SCAN_CRON_SECRET="replace-with-long-random-string"

# WeChat notifications (optional; set at least one channel)
# Enterprise WeCom robot webhook URL:
# WECOM_BOT_WEBHOOK_URL="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx"
#
# Personal WeChat via Server酱 Turbo:
# SERVERCHAN_SENDKEY="SCTxxxxxxxxxxxxxxxxxxxx"

# WeChat notification throttle window by (emailAccount + appointmentId), in minutes.
# Default: 30
# NOTIFY_THROTTLE_MINUTES=30

# Data retention window for saved rows (default 14 days).
# DATA_RETENTION_DAYS=14
